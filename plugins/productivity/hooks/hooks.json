{
  "PostToolUse": [
    {
      "matcher": "TodoWrite",
      "hooks": [
        {
          "type": "command",
          "command": "${PAI_DIR}/Hooks/sync-todo-to-md.mjs"
        }
      ]
    }
  ],
  "UserPromptSubmit": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "${PAI_DIR}/Hooks/cleanup-session-files.mjs"
        }
      ]
    }
  ]
}
