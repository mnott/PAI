{
  "PreCompact": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "${PAI_DIR}/Hooks/context-compression-hook.mjs"
        }
      ]
    },
    {
      "matcher": "",
      "hooks": [
        {
          "type": "command",
          "command": "${PAI_DIR}/Hooks/pai-pre-compact.sh"
        }
      ]
    }
  ],
  "SessionStart": [
    {
      "matcher": "compact",
      "hooks": [
        {
          "type": "command",
          "command": "${PAI_DIR}/Hooks/post-compact-inject.mjs"
        }
      ]
    }
  ]
}
